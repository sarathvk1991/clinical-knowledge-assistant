# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=clinical-knowledge
PINECONE_ENVIRONMENT=us-east-1

# App Settings
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_PORT=8000
FRONTEND_PORT=5173
# Set to your deployed frontend URL in production (e.g. https://my-app.onrender.com)
# Leave as * for development to allow all origins
FRONTEND_URL=*

# Embedding
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# LLM
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# Retrieval
RETRIEVAL_TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Reranking
RERANK_ENABLED=true
RERANK_TOP_K=5
